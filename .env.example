# --- Shared translated directory (was NOVEL_SHARE_DIR) ---
# Per-novel artefacts live here: translated/{novel}/{input,output,glossary,illustrations,...}
TRANSLATED_DIR=translated

# --- LLM provider ---
LLM_PROVIDER=ollama
FALLBACK_PROVIDER=gemini

# --- Crawler settings ---
MAX_CHAPTERS=0
USE_BROWSER=false
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# --- Provider endpoints ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

GEMINI_API_KEY=your-api-key
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=your-api-key
OPENROUTER_MODEL=qwen/qwen3-8b

# --- Translator settings ---
TARGET_LANGUAGE=vi
TRANSLATION_TEMPERATURE=0.3
TRANSLATION_MAX_TOKENS=4096
CHUNK_SIZE=1500
CHUNK_OVERLAP=100
REVIEW_THRESHOLD=0.7
MAX_RETRIES=2
ENABLE_REVIEW=false
ENABLE_SUMMARY=false
